# ============================================================
# GravityClaw — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to version control.
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# The Telegram user ID(s) allowed to use the bot (comma-separated)
ALLOWED_USER_IDS=123456789

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Pinecone (Vector Memory) ---
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=your_index_name
# e.g. us-east-1-aws
PINECONE_ENVIRONMENT=your_pinecone_environment

# --- Gmail (OAuth2) ---
GMAIL_CLIENT_ID=your_gmail_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:3000/oauth2callback
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# --- Apple iCloud Calendar (CalDAV) ---
APPLE_CALENDAR_URL=https://caldav.icloud.com/your/calendar/path/
APPLE_ID=your_apple_id@icloud.com
# Use an App-Specific Password from appleid.apple.com — NOT your real password
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Dashboard ---
# Port for the Express dashboard API
PORT=3200
# Set a strong secret token to protect the dashboard in production
DASHBOARD_TOKEN=change_me_to_a_strong_random_secret

# --- WTTJ Algolia (Required for Job Search) ---
WTTJ_ALGOLIA_APP_ID=
WTTJ_ALGOLIA_API_KEY=
